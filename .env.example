OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen3:8b

# Optional server-side access control for all /api/* routes.
# If set, clients must send this via `x-access-code` (or `access_code` query param for file-open routes).
APP_ACCESS_CODE=

# Basic in-memory per-IP rate limits.
API_RATE_WINDOW_SEC=60
API_RATE_LIMIT_REQS=120
API_RATE_LIMIT_ASK_REQS=60
API_RATE_LIMIT_PREPARE_REQS=8

# Production worker settings (used by Procfile command)
WEB_CONCURRENCY=2
WEB_TIMEOUT=180
